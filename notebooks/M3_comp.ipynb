      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.ticker as mticker\n",
        "\n",
        "np.random.seed(42)\n",
        "\n",
        "# ═══════════════════════════════════════════════════════════\n",
        "# PARTICIPATION RATES (from problem statement + estimates)\n",
        "# P(has active account) by age × gender\n",
        "# Source: 22% overall, ~50% men 18-49, scaled down for others\n",
        "# ═══════════════════════════════════════════════════════════\n",
        "participation = {  # (age_lo, age_hi): {M: rate, F: rate}\n",
        "    (18,25): {'M': 0.45, 'F': 0.15},\n",
        "    (25,35): {'M': 0.52, 'F': 0.18},\n",
        "    (35,50): {'M': 0.48, 'F': 0.14},\n",
        "    (50,65): {'M': 0.25, 'F': 0.08},\n",
        "    (65,99): {'M': 0.10, 'F': 0.03},\n",
        "}\n",
        "\n",
        "def get_participation(age, gender):\n",
        "    for (lo, hi), rates in participation.items():\n",
        "        if lo <= age < hi:\n",
        "            return rates[gender]\n",
        "    return 0.05\n",
        "\n",
        "# ═══════════════════════════════════════════════════════════\n",
        "# WAGERING MODEL\n",
        "# Annual wager = DI × base_fraction × risk_multiplier\n",
        "# Risk tolerance: 1 (conservative) to 5 (aggressive)\n",
        "# ═══════════════════════════════════════════════════════════\n",
        "# Base fraction: what share of DI a typical gambler wagers/year\n",
        "# US avg: ~$400/person, but only 22% gamble → ~$1800/gambler\n",
        "# Median DI ~$15K → ~12% of DI for average gambler\n",
        "BASE_WAGER_FRAC = 0.10  # base for risk=1 (calibrated to ~$15B US industry revenue)\n",
        "\n",
        "RISK_MULTIPLIERS = {1: 1.0, 2: 2.0, 3: 4.0, 4: 7.0, 5: 12.0}\n",
        "\n",
        "def annual_wager(disposable_income, risk_tolerance):\n",
        "    \"\"\"Annual amount wagered (not lost — total action).\"\"\"\n",
        "    if disposable_income <= 0:\n",
        "        # Problem gamblers may still wager from credit/savings\n",
        "        base = 2000\n",
        "    else:\n",
        "        base = disposable_income * BASE_WAGER_FRAC\n",
        "    return base * RISK_MULTIPLIERS[risk_tolerance]\n",
        "\n",
        "# ═══════════════════════════════════════════════════════════\n",
        "# HOUSE EDGE BY BET TYPE\n",
        "# Risk tolerance maps to bet type preference\n",
        "# Conservative → low-edge bets (spread/ML), Aggressive → parlays\n",
        "# ═══════════════════════════════════════════════════════════\n",
        "# Effective house edge (% of total wagered that becomes loss)\n",
        "EDGE_BY_RISK = {\n",
        "    1: 0.045,   # mostly spread bets, ~4.5% vig\n",
        "    2: 0.055,   # mix of spreads + some props\n",
        "    3: 0.080,   # props + small parlays\n",
        "    4: 0.120,   # parlays + live betting\n",
        "    5: 0.180,   # heavy parlays, longshots\n",
        "}\n",
        "\n",
        "# ═══════════════════════════════════════════════════════════\n",
        "# OUTCOME SIMULATION (Monte Carlo)\n",
        "# Model each bettor's year as N independent bets\n",
        "# ═══════════════════════════════════════════════════════════\n",
        "BETS_PER_YEAR = {1: 50, 2: 100, 3: 200, 4: 350, 5: 500}\n",
        "\n",
        "def simulate_year(wager, risk, n_sims=10000):\n",
        "    \"\"\"Simulate annual P&L for a bettor. Returns array of outcomes.\"\"\"\n",
        "    n_bets = BETS_PER_YEAR[risk]\n",
        "    bet_size = wager / n_bets\n",
        "    edge = EDGE_BY_RISK[risk]\n",
        "\n",
        "    # For spread-type bets: win prob ≈ (1 - edge) / (1 + 1) simplified\n",
        "    # More precisely: at -110 odds, you risk 110 to win 100\n",
        "    # We model as: each bet returns +bet_size with prob p, -bet_size with prob 1-p\n",
        "    # E[return per bet] = bet_size*(2p - 1) = -edge*bet_size\n",
        "    # → p = (1 - edge) / 2\n",
        "    # For parlays (high risk): bigger payouts, lower p\n",
        "    # We use a flexible model: each bet pays k*bet_size with prob p, else -bet_size\n",
        "\n",
        "    if risk <= 2:\n",
        "        # Standard bets: win ≈ 1× stake\n",
        "        payout_mult = 1.0\n",
        "        p_win = (1 - edge) / (1 + payout_mult)  # ensures E = -edge*bet_size\n",
        "    elif risk <= 3:\n",
        "        payout_mult = 1.5\n",
        "        p_win = (1 - edge) / (1 + payout_mult)\n",
        "    elif risk <= 4:\n",
        "        payout_mult = 3.0\n",
        "        p_win = (1 - edge) / (1 + payout_mult)\n",
        "    else:\n",
        "        payout_mult = 6.0\n",
        "        p_win = (1 - edge) / (1 + payout_mult)\n",
        "\n",
        "    # Simulate\n",
        "    wins = np.random.binomial(n_bets, p_win, size=n_sims)\n",
        "    losses = n_bets - wins\n",
        "    pnl = wins * payout_mult * bet_size - losses * bet_size\n",
        "    return pnl\n",
        "\n",
        "def expected_loss(wager, risk):\n",
        "    \"\"\"Deterministic expected annual loss.\"\"\"\n",
        "    return -wager * EDGE_BY_RISK[risk]\n",
        "\n",
        "# ═══════════════════════════════════════════════════════════\n",
