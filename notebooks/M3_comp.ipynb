        "    (50,65): {'M': 31.0, 'F': 32.0},\n",
        "    (65,99): {'M': 24.0, 'F': 28.0},\n",
        "}\n",
        "\n",
        "# Average DI by age bracket (rough from Q1 / BLS)\n",
        "avg_di = {(18,25): 5000, (25,35): 13000, (35,50): 20000, (50,65): 15000, (65,99): 8000}\n",
        "avg_risk = {(18,25): 3.2, (25,35): 2.8, (35,50): 2.3, (50,65): 1.8, (65,99): 1.3}\n",
        "\n",
        "total_losses = 0\n",
        "total_gamblers = 0\n",
        "\n",
        "for bracket, pops in us_pop.items():\n",
