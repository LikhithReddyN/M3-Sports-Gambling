        "\n",
        "        # Interpolate risk multiplier and edge\n",
        "        r_lo, r_hi = int(risk_avg), min(int(risk_avg) + 1, 5)\n",
        "        frac = risk_avg - r_lo\n",
        "        rm = RISK_MULTIPLIERS[r_lo] * (1-frac) + RISK_MULTIPLIERS[r_hi] * frac\n",
        "        edge = EDGE_BY_RISK[r_lo] * (1-frac) + EDGE_BY_RISK[r_hi] * frac\n",
        "\n",
        "        avg_wager = di * BASE_WAGER_FRAC * rm\n",
        "        loss_per = avg_wager * edge\n",
